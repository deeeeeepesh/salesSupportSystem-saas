# Database
DATABASE_URL=postgresql://user:password@localhost:5432/salesdb

# Auth
NEXTAUTH_SECRET=your-super-secret-key-change-this
NEXTAUTH_URL=http://localhost:3000
SUPER_ADMIN_SECRET=separate-super-secret-for-admin-portal

# Google Sheets (per-tenant — customers add their own credentials in the admin panel)
GOOGLE_SHEETS_CREDENTIALS='{"type":"service_account",...}'

# Redis
REDIS_URL=redis://localhost:6379

# Razorpay
RAZORPAY_KEY_ID=rzp_live_xxxx
RAZORPAY_KEY_SECRET=xxxx
RAZORPAY_WEBHOOK_SECRET=xxxx

# Pricing (in paise - INR)
PRICE_STORE_BASE=200000
PRICE_EXTRA_SALES_SEAT=20000
PRICE_EXTRA_MANAGER_SEAT=50000
PRICE_EXTRA_ADMIN_SEAT=70000
PRICE_EXTRA_BRANCH=200000

# App Config
NEXT_PUBLIC_ROOT_DOMAIN=salessupportapp.dedasystems.com
PRICE_AUTHORITY_ENABLED=true
PRICE_MAX_VALID_MS=300000
PRICE_SYNC_INTERVAL_MS=120000
