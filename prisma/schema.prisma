generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── TENANT ──────────────────────────────────────────────────────────────────

model Tenant {
  id              String         @id @default(cuid())
  name            String
  slug            String         @unique  // subdomain slug
  email           String         @unique  // owner email
  phone           String?
  status          TenantStatus   @default(TRIAL)
  trialEndsAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  // Razorpay
  razorpayCustomerId     String?
  razorpaySubscriptionId String?

  // Google Sheets (per-tenant)
  googleSheetId   String?

  // Relations
  users           User[]
  products        CachedProduct[]
  priceMeta       PriceListMeta[]
  subscription    Subscription?

  @@map("tenants")
}

enum TenantStatus {
  TRIAL
  ACTIVE
  SUSPENDED
  CANCELLED
}

// ─── SUBSCRIPTION ─────────────────────────────────────────────────────────────

model Subscription {
  id                    String             @id @default(cuid())
  tenantId              String             @unique
  tenant                Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  razorpaySubscriptionId String?           @unique
  planId                String?
  status                SubscriptionStatus @default(TRIAL)
  currentPeriodStart    DateTime?
  currentPeriodEnd      DateTime?
  salesSeats            Int                @default(0)
  managerSeats          Int                @default(0)
  adminSeats            Int                @default(0)
  monthlyAmount         Int                @default(0)  // in paise
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  @@map("subscriptions")
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELLED
  SUSPENDED
}

// ─── USER ─────────────────────────────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  email           String
  name            String
  password        String
  role            Role      @default(SALES)
  isActive        Boolean   @default(true)
  activeSessionId String?
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  totalVisits     Int       @default(0)
  totalPageViews  Int       @default(0)
  totalDuration   Int       @default(0)
  totalRefreshes  Int       @default(0)
  lastActiveAt    DateTime?

  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([email, tenantId])
  @@index([tenantId])
  @@map("users")
}

enum Role {
  SALES
  ADMIN
  STORE_MANAGER
}

// ─── PRICE LIST META ──────────────────────────────────────────────────────────

model PriceListMeta {
  id                   String   @id @default(cuid())
  tenantId             String   @unique
  tenant               Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  version              Int      @default(0)
  lastSyncedAt         DateTime @default(now())
  lastSheetHash        String   @default("")
  syncInProgress       Boolean  @default(false)
  maxValidDurationMs   Int      @default(300000)
  updatedAt            DateTime @updatedAt

  @@map("price_list_meta")
}

// ─── CACHED PRODUCT ───────────────────────────────────────────────────────────

model CachedProduct {
  id                    String   @id
  tenantId              String
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  brand                 String
  model                 String
  image                 String
  variant               String
  mrp                   Float?
  mop                   Float?
  finalPrice            Float?
  selloutMop            Float?
  selloutFinal          Float?
  selloutFromDate       String?
  selloutToDate         String?
  lastUpdated           String?
  quickPitch            String?
  bankOffers            String?
  upgradeExchangeOffers String?
  storeOffersGifts      String?
  weeklyFocus           Boolean  @default(false)
  allModels             Boolean  @default(false)
  newLaunch             Boolean  @default(false)
  ram                   Int?
  rom                   Int?
  version               Int
  createdAt             DateTime @default(now())

  @@index([tenantId, version])
  @@index([tenantId, brand])
  @@map("cached_products")
}

// ─── SUPER ADMIN ──────────────────────────────────────────────────────────────

model SuperAdmin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("super_admins")
}
